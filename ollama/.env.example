# Copy this file to .env and fill in the values

# Required — set a strong random string (e.g. run: openssl rand -hex 32)
WEBUI_SECRET_KEY=change-this-to-a-random-string

# Google OAuth (optional but recommended — see README)
# Set ENABLE_OAUTH_SIGNUP=true so new users can sign up via Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ENABLE_OAUTH_SIGNUP=true

# Cloudflare Tunnel (Phase 2 — remote access from school)
CLOUDFLARE_TUNNEL_TOKEN=
