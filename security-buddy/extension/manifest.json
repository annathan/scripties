{
  "manifest_version": 3,
  "name": "Safety Buddy",
  "version": "1.0.0",
  "description": "Keeps you safe online by checking links before you visit them.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/buddy-16.png",
      "48": "icons/buddy-48.png",
      "128": "icons/buddy-128.png"
    }
  },
  "icons": {
    "16": "icons/buddy-16.png",
    "48": "icons/buddy-48.png",
    "128": "icons/buddy-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["warning.html", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "safety-buddy@scripties"
    }
  }
}
