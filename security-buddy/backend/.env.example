# === Google Safe Browsing ===
# Get a free key at https://console.cloud.google.com → APIs & Services → Safe Browsing API
GOOGLE_SAFE_BROWSING_API_KEY=

# === Anthropic (Claude) ===
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# === Database ===
# Leave blank to use local SQLite (safety_buddy.db)
# For Railway PostgreSQL: copy the URL from the Railway dashboard
DATABASE_URL=

# === Email (SMTP) ===
# For Gmail: use an App Password (not your account password)
# Generate at https://myaccount.google.com → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here
FROM_EMAIL=your-gmail@gmail.com

# === Twilio SMS (optional — Pro plan users only) ===
# Free trial at https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# === Stripe (for billing) ===
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Create a recurring price in the Stripe dashboard and paste its ID here
STRIPE_PRO_PRICE_ID=price_...
# Webhook secret: from Stripe dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# === App URL ===
# Used for Stripe redirect URLs. Set to your Railway/Fly.io domain in production.
APP_URL=http://localhost:8000

# === CORS ===
# Comma-separated list of allowed origins. Use * for local dev only.
ALLOWED_ORIGINS=*
