# === Google Safe Browsing ===
# Get a free key at https://console.cloud.google.com → APIs & Services → Safe Browsing API
GOOGLE_SAFE_BROWSING_API_KEY=

# === Anthropic (Claude) ===
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# === Database ===
# Leave blank to use local SQLite (safety_buddy.db)
# For Railway PostgreSQL: copy the URL from the Railway dashboard
DATABASE_URL=

# === Email (SMTP) ===
# For Gmail: use an App Password (not your account password)
# Generate at https://myaccount.google.com → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here
FROM_EMAIL=your-gmail@gmail.com

# === Twilio SMS (optional — Pro plan users only) ===
# Free trial at https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# === Stripe (for billing) ===
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret: Stripe dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
#
# Create one Price in the Stripe dashboard for each of the five products below.
# Annual prices: recurring, yearly interval.
# Lifetime / API renewal prices: one-time payment.
STRIPE_PERSONAL_ANNUAL_PRICE_ID=price_...    # $9.99/yr  — recurring
STRIPE_FAMILY_ANNUAL_PRICE_ID=price_...      # $19.99/yr — recurring
STRIPE_PERSONAL_LIFETIME_PRICE_ID=price_...  # $24.99    — one-time (incl. 2yr API checking)
STRIPE_FAMILY_LIFETIME_PRICE_ID=price_...    # $49.99    — one-time (incl. 2yr API checking)
STRIPE_API_RENEWAL_PRICE_ID=price_...        # $9.99     — one-time (extends API checking 2yr)

# === App URL ===
# Used for Stripe redirect URLs. Set to your Railway/Fly.io domain in production.
APP_URL=http://localhost:8000

# === CORS ===
# Comma-separated list of allowed origins. Use * for local dev only.
ALLOWED_ORIGINS=*
